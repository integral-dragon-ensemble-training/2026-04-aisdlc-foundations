{
  "_comment": "Claude Code settings for the Ensemble scorecard-gathering session. Allowlist-based — pre-approves safe tools and commands so Claude doesn't prompt for them, while denying destructive / network-egressing / secret-reading operations outright. Does NOT use --dangerously-skip-permissions. To activate: symlink or copy this file to .claude/settings.json at the repo root. Launch Claude with --permission-mode acceptEdits to also auto-accept file edits.",
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(research/scorecard/runs/**)",
      "Edit(research/scorecard/runs/**)",
      "Bash(mkdir *)",
      "Bash(ls *)", "Bash(ls)",
      "Bash(pwd)",
      "Bash(tree *)",
      "Bash(cat *)",
      "Bash(head *)", "Bash(tail *)",
      "Bash(grep *)", "Bash(rg *)",
      "Bash(find *)",
      "Bash(jq *)",
      "Bash(sort *)", "Bash(uniq *)", "Bash(wc *)",
      "Bash(awk *)", "Bash(sed *)",
      "Bash(date *)",
      "Bash(echo *)", "Bash(printf *)",
      "Bash(file *)", "Bash(stat *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(python3 *)",
      "Bash(node *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git checkout --*)",
      "Bash(rm *)",
      "Bash(sudo *)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(pip install *)",
      "Bash(pip uninstall *)",
      "Bash(npx *)",
      "Bash(brew *)",
      "Read(~/**/.ssh/**)",
      "Read(~/**/.aws/**)",
      "Read(~/**/.config/gh/**)",
      "Read(~/**/.netrc)",
      "Write(~/**)",
      "Write(/**)"
    ]
  }
}
