      "link": null,
      "locked": false,
      "text": "COVERAGE\n\nA percentage.\n\nCan be high while tests\nassert implementation trivia,\nrun flakily, or test the\nwrong behavior.",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "frame-02-coverage-rect",
      "originalText": "COVERAGE\n\nA percentage.\n\nCan be high while tests\nassert implementation trivia,\nrun flakily, or test the\nwrong behavior.",
      "autoResize": false,
      "lineHeight": 1.25
    },
